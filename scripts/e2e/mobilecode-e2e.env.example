# Copy this file to ~/.mobilecode-e2e.env or ./.mobilecode-e2e.env and fill it locally.
# Never commit real cloud tokens. The repository-level ./.mobilecode-e2e.env is gitignored.
#
# Run with:
#   scripts/e2e/run-opencode-cloud-ux.sh
# Or with an explicit env file:
#   scripts/e2e/run-opencode-cloud-ux.sh /absolute/path/to/mobilecode-e2e.env

# Required. Supported values: digitalocean, hetzner.
MOBILECODE_E2E_PROVIDER=digitalocean

# Required. Use a temporary read/write token for a test team/project.
# DigitalOcean tokens usually start with dop_v1_.
MOBILECODE_E2E_CLOUD_TOKEN="replace-with-read-write-cloud-token"

# Required for the create/delete UX test. The runner refuses cloud mutation unless this is exactly 1.
MOBILECODE_E2E_ALLOW_CLOUD_MUTATION=1

# Optional. Override where the runner looks for this file when no path argument is passed.
# MOBILECODE_E2E_ENV_FILE="$HOME/.mobilecode-e2e.env"

# Optional. Stable id used for generated names. Defaults to current UTC timestamp.
# MOBILECODE_E2E_RUN_ID=20260504123000

# Optional. Provider label typed into the app. Defaults to "MobileCode E2E <Provider> <run id>".
# MOBILECODE_E2E_PROVIDER_NAME="MobileCode E2E DigitalOcean 20260504123000"

# Optional. Cleanup deletes only cloud server names beginning with this prefix.
# The cleanup guard refuses prefixes shorter than 8 chars or prefixes that do not contain "e2e".
MOBILECODE_E2E_SERVER_NAME_PREFIX=mobilecode-e2e

# Optional. Full cloud server name. Defaults to "$MOBILECODE_E2E_SERVER_NAME_PREFIX-$MOBILECODE_E2E_RUN_ID".
# MOBILECODE_E2E_SERVER_NAME=mobilecode-e2e-20260504123000

# Optional. SSH key name generated through the app. Defaults to "$MOBILECODE_E2E_SERVER_NAME-key".
# MOBILECODE_E2E_SSH_KEY_NAME=mobilecode-e2e-20260504123000-key
#
# Optional. By default the shell runner generates a temporary host-side Ed25519 key,
# seeds it into the simulator app, uploads the public key to the cloud provider, and
# removes the local private key during cleanup. Set these only when you want to reuse
# a known test key for live SSH debugging while the E2E run is still active.
# MOBILECODE_E2E_SSH_PRIVATE_KEY_PATH=scripts/e2e/.generated/mobilecode-e2e-debug_ed25519
# MOBILECODE_E2E_SSH_PUBLIC_KEY_PATH=scripts/e2e/.generated/mobilecode-e2e-debug_ed25519.pub

# Optional. Agent name created after provisioning when an AI API key is provided.
# Defaults to "$MOBILECODE_E2E_SERVER_NAME-agent".
# MOBILECODE_E2E_AGENT_NAME=mobilecode-e2e-20260504123000-agent

# Optional. If set, the live UX test continues after server creation, creates an agent,
# opens Settings -> Agent Runtime, and saves this key through the OpenCode API-key UI.
# MiniMax is the default provider id for this harness.
MOBILECODE_E2E_AI_PROVIDER_ID=minimax
# MOBILECODE_E2E_AI_API_KEY="replace-with-minimax-api-key"

# Optional. If set, the runtime settings screen autofills and saves model selection.
# Use OpenCode's provider/model id shape. The runner defaults both MiniMax fields
# to MiniMax-M2.7 when MOBILECODE_E2E_AI_API_KEY is present and the provider is minimax.
MOBILECODE_E2E_AI_MODEL_ID=minimax/MiniMax-M2.7
MOBILECODE_E2E_AI_SMALL_MODEL_ID=minimax/MiniMax-M2.7

# Optional. Keep this as 1 for normal test runs. The shell runner pre-cleans and post-cleans
# all servers with the safe E2E prefix, and the UI test also deletes the exact server name
# during teardown when run directly from Xcode.
# Set to 0 only when intentionally debugging a live server after the test.
MOBILECODE_E2E_DELETE_CREATED_SERVERS=1

# Optional. If unset, the UI-test autofill picks the first available region and cheapest matching size.
# DigitalOcean examples: nyc3, sfo3, fra1 with sizes like s-1vcpu-1gb, s-1vcpu-2gb.
# Hetzner examples: fsn1, nbg1, hel1 with sizes like cx22, cpx11.
# MOBILECODE_E2E_REGION=nyc3
# MOBILECODE_E2E_SIZE=s-1vcpu-1gb

# Optional. How long the UI test waits for provisioning/runtime setup to become actionable.
MOBILECODE_E2E_PROVISIONING_TIMEOUT_SECONDS=1800

# Optional. Simulator destination passed to xcodebuild.
MOBILECODE_E2E_DESTINATION="platform=iOS Simulator,name=iPhone 17 Pro,OS=26.4.1"

# Optional. Keep this at 0 for stable automated runs. Xcode may run UI tests in a
# private XCTest device, so pre-opening Simulator.app can leave a second idle window.
# Set to 1 only when you intentionally want to watch the normal target simulator too.
MOBILECODE_E2E_SHOW_SIMULATOR=0
# MOBILECODE_E2E_SIMULATOR_DEVICE="iPhone 17 Pro"

# Internal/test-harness variable. Enabled by the shell runner so provisioning state is
# written to Documents/mobilecode-e2e-provisioning.log inside the simulator app container.
# MOBILECODE_E2E_PROVISIONING_DEBUG_LOG=1

# Internal/test-harness variables. The runner sets these automatically for the create-server test.
# MOBILECODE_E2E_AUTOFILL_CLOUD_SERVER=1
# MOBILECODE_E2E_AUTOFILL_AI_API_KEY=1
